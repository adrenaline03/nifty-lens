# Template for Streamlit Cloud secrets configuration.
# When deploying to Streamlit Cloud, copy these keys into the app's
# "Secrets" settings panel (Settings → Secrets) with real values.
#
# DO NOT commit a populated secrets.toml to git — that file is gitignored.

[neon]
user = "your_neon_user"
password = "your_neon_password"
host = "your-host.neon.tech"
port = "5432"
database = "neondb"